{
  "version": 1,
  "default_category": "互联网与科技趋势",
  "sources": {
    "ai-newsletters": {
      "name": "AI Newsletters",
      "kind": "auto",
      "collector": "rss_bundle",
      "labels": ["analysis", "trigger"],
      "feeds": [
        {"name": "TLDR AI", "url": "https://bullrich.dev/tldr-rss/ai.rss"},
        {"name": "The Rundown AI", "url": "https://rss.beehiiv.com/feeds/2R3C6Bt5wj.xml"}
      ],
      "description": "AI newsletter feeds for model, agent, product, and workflow updates."
    },
    "ai-products": {
      "name": "AI Products",
      "kind": "auto",
      "collector": "ai_products",
      "labels": ["analysis", "trigger", "product"],
      "feeds": [
        {"name": "Product Hunt", "url": "https://www.producthunt.com/feed"},
        {"name": "GitHub Trending Python", "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/python.xml"},
        {"name": "Techmeme", "url": "https://www.techmeme.com/feed.xml"}
      ],
      "description": "Product-launch oriented bundle using Product Hunt RSS, Show HN, GitHub Trending, and Techmeme."
    },
    "hackernews": {
      "name": "Hacker News",
      "kind": "auto",
      "collector": "hackernews",
      "labels": ["community", "trigger"],
      "description": "HN top stories for auto discovery and Algolia story search for topic mode."
    },
    "arxiv": {
      "name": "arXiv",
      "kind": "auto",
      "collector": "arxiv",
      "requires_topic": true,
      "labels": ["primary", "research"],
      "description": "arXiv Atom API for technical and academic grounding."
    },
    "techmeme": {
      "name": "Techmeme",
      "kind": "auto",
      "collector": "rss",
      "url": "https://www.techmeme.com/feed.xml",
      "labels": ["analysis", "trigger"],
      "description": "Technology and business news feed."
    },
    "producthunt-rss": {
      "name": "Product Hunt RSS",
      "kind": "auto",
      "collector": "rss",
      "url": "https://www.producthunt.com/feed",
      "labels": ["analysis", "trigger", "product"],
      "description": "Public Product Hunt RSS feed."
    },
    "github-trending": {
      "name": "GitHub Trending",
      "kind": "auto",
      "collector": "rss",
      "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/python.xml",
      "labels": ["primary", "trigger", "code"],
      "description": "Daily GitHub Trending RSS for open-source projects."
    },
    "global-search": {
      "name": "Zhihu Global Search",
      "kind": "credentialed",
      "collector": "zhihu_global",
      "requires_env": ["ZHIHU_ACCESS_SECRET"],
      "requires_topic": true,
      "labels": ["analysis", "community"],
      "description": "Zhihu OpenAPI global web search."
    },
    "zhihu-search": {
      "name": "Zhihu Search",
      "kind": "credentialed",
      "collector": "zhihu_search",
      "requires_env": ["ZHIHU_ACCESS_SECRET"],
      "requires_topic": true,
      "labels": ["analysis", "community"],
      "description": "Zhihu OpenAPI in-site search."
    },
    "hot-list": {
      "name": "Zhihu Hot List",
      "kind": "credentialed",
      "collector": "zhihu_hot",
      "requires_env": ["ZHIHU_ACCESS_SECRET"],
      "labels": ["community", "trigger"],
      "description": "Zhihu OpenAPI hot list."
    },
    "producthunt-api": {
      "name": "Product Hunt API",
      "kind": "credentialed",
      "collector": "producthunt_api",
      "requires_any_env_sets": [
        ["PRODUCTHUNT_ACCESS_TOKEN"],
        ["PRODUCTHUNT_API_KEY", "PRODUCTHUNT_API_SECRET"]
      ],
      "labels": ["primary", "product", "trigger"],
      "description": "Official Product Hunt GraphQL API using PRODUCTHUNT_ACCESS_TOKEN or client credentials."
    },
    "blockbeats-skill": {
      "name": "BlockBeats Search and News",
      "kind": "credentialed",
      "collector": "blockbeats_search",
      "requires_env": ["BLOCKBEATS_API_KEY"],
      "labels": ["analysis", "trigger", "market"],
      "description": "BlockBeats crypto news, search, and article API."
    },
    "blockbeats-market": {
      "name": "BlockBeats Market Data",
      "kind": "credentialed",
      "collector": "blockbeats_market",
      "requires_env": ["BLOCKBEATS_API_KEY"],
      "labels": ["primary", "market"],
      "description": "BlockBeats market, ETF, stablecoin, and on-chain data endpoints."
    },
    "blockbeats-macro": {
      "name": "BlockBeats Macro Data",
      "kind": "credentialed",
      "collector": "blockbeats_macro",
      "requires_env": ["BLOCKBEATS_API_KEY"],
      "labels": ["primary", "macro"],
      "description": "BlockBeats M2, US10Y, DXY, and compliant exchange asset endpoints."
    },
    "folo": {
      "name": "Folo",
      "kind": "credentialed",
      "collector": "folo_trending",
      "requires_env": ["FOLO_TOKEN"],
      "requires_cli": ["npx"],
      "labels": ["analysis", "rss"],
      "description": "Folo RSS reader trending/search timeline via folocli."
    },
    "last30days": {
      "name": "last30days",
      "kind": "deep",
      "collector": "manual",
      "description": "Deep recent-community research across Reddit, X, YouTube, TikTok, HN, GitHub, Polymarket, and the web."
    },
    "twitter-cli": {
      "name": "Twitter/X",
      "kind": "deep",
      "collector": "manual",
      "description": "Twitter/X search and account research; requires twitter-cli authentication."
    },
    "blogwatcher": {
      "name": "Blogwatcher",
      "kind": "deep",
      "collector": "manual",
      "description": "Subscribed blog and RSS monitoring via blogwatcher-cli."
    },
    "xiaohongshu": {
      "name": "Xiaohongshu",
      "kind": "manual",
      "collector": "manual",
      "description": "RedNote/Xiaohongshu search, trend, note details, and comments; requires MCP service and login."
    },
    "youtube-content": {
      "name": "YouTube Content",
      "kind": "manual",
      "collector": "manual",
      "description": "YouTube transcripts and summaries; requires a specific YouTube URL or video ID."
    },
    "watch": {
      "name": "Watch",
      "kind": "manual",
      "collector": "manual",
      "description": "Video URL/local video analysis with transcripts and frames."
    },
    "wechat-article-extractor": {
      "name": "WeChat Article Extractor",
      "kind": "manual",
      "collector": "manual",
      "description": "Extract metadata and content from provided mp.weixin.qq.com article URLs."
    },
    "mptext-wechat-article-fetcher": {
      "name": "MPText WeChat Fetcher",
      "kind": "manual",
      "collector": "manual",
      "description": "Search/fetch WeChat official account articles with an MPText API key."
    },
    "read-arxiv-paper": {
      "name": "Read arXiv Paper",
      "kind": "deep",
      "collector": "manual",
      "description": "Full arXiv source reading after a specific paper is selected."
    },
    "research": {
      "name": "Research Coordinator",
      "kind": "deep",
      "collector": "manual",
      "description": "Multi-agent deep research workflow for complex topics."
    },
    "producthunt-comments": {
      "name": "Product Hunt Comments",
      "kind": "deep",
      "collector": "manual",
      "description": "Comment-level product research through Product Hunt API after selecting a post."
    },
    "polymarket-last30days": {
      "name": "Polymarket via last30days",
      "kind": "deep",
      "collector": "manual",
      "description": "Prediction-market angle through last30days Polymarket support."
    },
    "blockbeats-hyperliquid": {
      "name": "Hyperliquid via BlockBeats",
      "kind": "deep",
      "collector": "manual",
      "description": "Hyperliquid/on-chain follow-up through BlockBeats endpoints."
    }
  },
